# PowerPoint MCP Server Configuration
# Copy this file to .env and modify values as needed

# Server Configuration
# PPT_MCP_PORT=8000
# PPT_MCP_TRANSPORT=stdio

# Template Paths (colon-separated on Unix, semicolon-separated on Windows)
# PPT_TEMPLATE_PATH=/path/to/templates:/another/path

# Font Size Configuration (in points)
# PPT_MIN_FONT_SIZE=8
# PPT_MAX_FONT_SIZE=72

# Slide Dimensions (in EMU - English Metric Units)
# Standard slide is 10" x 7.5" = 9144000 x 6858000 EMU
# PPT_SLIDE_WIDTH_EMU=9144000
# PPT_SLIDE_HEIGHT_EMU=6858000

# Shape Spacing (in EMU)
# PPT_MIN_SPACING_EMU=91440  # 0.1 inches